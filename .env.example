# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

TRADOVATE_USERNAME=your_username
TRADOVATE_PASSWORD=your_password

# App credentials from the Tradovate developer portal.
# The demo defaults below work for the demo environment.
TRADOVATE_APP_ID=Sample App
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=8
TRADOVATE_SECRET=your-app-secret

# Use "demo" to test without risking real money, "live" for production.
TRADOVATE_ENV=demo
